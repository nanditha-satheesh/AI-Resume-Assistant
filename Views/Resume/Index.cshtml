@{
    ViewData["Title"] = "AI Resume Assistant";
    ViewData["HideFooter"] = true;
    var chatHistory = ViewBag.ChatHistory as List<AIResumeAssistant.Models.ChatMessage> ?? new List<AIResumeAssistant.Models.ChatMessage>();
    var hasResume = (bool)(ViewBag.HasResume ?? false);
    var promptModes = ViewBag.PromptModes as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<style>
    /* Make the resume page fill remaining viewport below the navbar */
    .chat-layout { height: calc(100vh - 56px); }
</style>

<div class="container-fluid px-0">
    <div class="row g-0 chat-layout">
        <!-- Sidebar -->
        <div class="col-md-3 border-end d-flex flex-column" style="background-color: #f0f2f5;">
            <div class="p-3 text-white fw-bold" style="background: linear-gradient(135deg, #1a1a2e, #0f3460);">
                📄 AI Resume Assistant
            </div>

            <div class="p-3 overflow-auto flex-grow-1">
                <!-- File Upload -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold mb-2">📤 Upload Resume</h6>
                        <input type="file" class="form-control form-control-sm mb-2" id="resumeFile" accept=".pdf" />
                        <button class="btn btn-primary btn-sm w-100" id="btnUpload" onclick="uploadResume()">
                            <span id="uploadSpinner" class="spinner-border spinner-border-sm d-none me-1" role="status"></span>
                            Upload PDF
                        </button>
                        <div id="uploadStatus" class="mt-2 small"></div>
                    </div>
                </div>

                <!-- Prompt Mode Selector -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold mb-2">🎭 AI Persona</h6>
                        <select class="form-select form-select-sm" id="promptMode">
                            @foreach (var mode in promptModes)
                            {
                                <option value="@mode.Key">@mode.Value</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold mb-2">⚡ Quick Actions</h6>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary btn-sm text-start rounded-pill" onclick="sendQuickAction('Improve my resume summary')">
                                ✨ Improve Summary
                            </button>
                            <button class="btn btn-outline-primary btn-sm text-start rounded-pill" onclick="sendQuickAction('Generate a cover letter based on my resume')">
                                📝 Generate Cover Letter
                            </button>
                            <button class="btn btn-outline-primary btn-sm text-start rounded-pill" onclick="sendQuickAction('Suggest missing skills for my resume')">
                                🎯 Suggest Missing Skills
                            </button>
                            <button class="btn btn-outline-primary btn-sm text-start rounded-pill" onclick="sendQuickAction('Rewrite my experience section more professionally')">
                                💼 Rewrite Experience
                            </button>
                            <button class="btn btn-outline-primary btn-sm text-start rounded-pill" onclick="sendQuickAction('Review my resume and provide overall feedback')">
                                📋 Overall Review
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Session Controls -->
            <div class="p-3 border-top">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-success btn-sm rounded-pill" id="btnDownload" onclick="downloadResponse()" disabled>
                        ⬇️ Download Last Response
                    </button>
                    <button class="btn btn-outline-danger btn-sm rounded-pill" onclick="clearSession()">
                        🗑️ Clear Session
                    </button>
                </div>
            </div>
        </div>

        <!-- Chat Area -->
        <div class="col-md-9 d-flex flex-column" style="background-color: #e5e5ea;">
            <!-- Chat Messages -->
            <div class="flex-grow-1 overflow-auto p-4" id="chatMessages">
                @if (!chatHistory.Any())
                {
                    <div class="text-center mt-5" id="welcomeMessage">
                        <div class="card border-0 shadow-sm mx-auto p-4" style="max-width: 500px; background: white;">
                            <h4 class="fw-bold">👋 Welcome!</h4>
                            <p class="text-muted mb-2">Upload your resume (PDF) and ask me anything:</p>
                            <ul class="list-unstyled text-muted">
                                <li class="mb-1">✨ "Improve my resume summary"</li>
                                <li class="mb-1">📝 "Generate a cover letter"</li>
                                <li class="mb-1">🎯 "Suggest missing skills"</li>
                                <li class="mb-1">💼 "Rewrite my experience professionally"</li>
                            </ul>
                        </div>
                    </div>
                }
                else
                {
                    foreach (var msg in chatHistory)
                    {
                        if (msg.Role == "user")
                        {
                            <div class="d-flex justify-content-end mb-3">
                                <div class="text-white rounded-4 p-3 shadow-sm" style="max-width: 70%; background: linear-gradient(135deg, #0f3460, #1a1a2e);">
                                    <div class="small fw-bold mb-1 opacity-75">You</div>
                                    <div>@msg.Content</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-start mb-3">
                                <div class="bg-white rounded-4 p-3 shadow-sm" style="max-width: 70%;">
                                    <div class="small fw-bold text-primary mb-1">🤖 AI Assistant</div>
                                    <div class="ai-response" style="white-space: pre-wrap;">@msg.Content</div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>

            <!-- Loading Indicator -->
            <div class="px-4 d-none" id="loadingIndicator">
                <div class="d-flex align-items-center mb-2">
                    <div class="bg-white rounded-4 p-3 shadow-sm">
                        <div class="d-flex align-items-center text-muted">
                            <div class="spinner-grow spinner-grow-sm text-primary me-2" role="status"></div>
                            <span>AI is thinking...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="p-3" style="background: white; border-top: 1px solid #ddd;">
                <div class="input-group shadow-sm rounded-pill overflow-hidden">
                    <textarea class="form-control border-0 py-2 px-3" id="userQuestion" rows="1"
                              placeholder="Ask something about your resume..."
                              onkeydown="handleKeyDown(event)"
                              style="resize: none;"></textarea>
                    <button class="btn btn-primary px-4" id="btnSend" onclick="askAI()" style="border-radius: 0;">
                        Send ➤
                    </button>
                </div>
                <div class="d-flex justify-content-between mt-2 px-1">
                    <small id="resumeStatus" class="@(hasResume ? "text-success" : "text-warning")">
                        @(hasResume ? "✅ Resume loaded" : "⚠️ No resume uploaded")
                    </small>
                    <small class="text-muted">Ctrl+Enter to send</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/resume.js" asp-append-version="true"></script>
}
